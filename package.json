{
  "name": "yugioh-app",
  "private": true,
  "version": "1.0.0",
  "description": "Comprehensive Yu-Gi-Oh! card database, deck builder, and information hub for duelists of all levels.",
  "keywords": [
    "yugioh",
    "yu-gi-oh",
    "card-database",
    "deck-builder",
    "trading-card-game",
    "card-game",
    "duel-monsters",
    "card-search",
    "tcg",
    "konami",
    "card-collection",
    "deck-builder-tool",
    "card-info",
    "card-database",
    "dueling",
    "card-game-tool"
  ],
  "type": "module",
  "main": "main.mjs",
  "license": "ISC",
  "author": "Joan Cerepi",
  "scripts": {
    "dev": "vite",
    "build": "vite build --emptyOutDir",
    "preview": "vite preview",
    "lint": "eslint *.js src/**/*.js src/**/*.mjs",
    "format": "prettier --ignore-path ./.gitignore --write \"./**/*.{html,json,js,css}\""
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/node": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@eslint/js": "^9.15.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.12.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.1",
    "vite": "^6.0.1"
  },
  "browserslist": [
    "last 3 and_chr versions",
    "last 3 chrome versions",
    "last 3 opera versions",
    "last 3 ios_saf versions",
    "last 3 safari versions"
  ]
